  "scripts": {
    "stamp": "echo \"export const GIT_COMMIT_HASH = \\\"$(git rev-parse HEAD)\\\";\" > src/version.ts",
    "build": "npm run stamp && npm run eslint && rm -rf dist/ && tsc && tsc-alias",
    "build:tsup": "npm run stamp && npm run eslint && rm -rf dist/ && tsc && tsup --sourcemap",
    "eslint": "eslint -c eslint.config.ts src/"
  },
